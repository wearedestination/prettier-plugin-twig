#!/usr/bin/env node

const path = require('path');
const fs = require('fs').promises;
const root = path.resolve(__dirname, '../src');

function relativeToRootPath(target, dirname) {
  return path.relative(root, path.resolve(dirname, target));
}

async function findTsFiles(dir) {
  const entries = await fs.readdir(dir, { withFileTypes: true });
  const files = await Promise.all(
    entries.map((entry) => {
      const full = path.join(dir, entry.name);
      if (entry.isDirectory()) return findTsFiles(full);
      if (entry.isFile() && entry.name.endsWith('.ts')) return [full];
      return [];
    }),
  );
  return files.flat();
}

async function relativeReplace(filePath) {
  const contents = await fs.readFile(filePath, 'utf8');
  const result = contents.replaceAll(/from '(\.[^']*)'/g, (_match, target) => {
    return `from '~/${relativeToRootPath(target, path.dirname(filePath))}'`;
  });
  if (result !== contents) {
    await fs.writeFile(filePath, result, 'utf8');
  }
}

async function run() {
  const files = await findTsFiles(root);
  await Promise.all(files.map(relativeReplace));
}

async function main() {
  let statusCode = 0;
  try {
    await run();
  } catch (e) {
    console.log(e);
    statusCode = 1;
  }
  process.exit(statusCode);
}

void main();
